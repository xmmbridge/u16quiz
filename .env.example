# Public, used by the browser app (safe to expose - Netlify env vars, prefixed VITE_ so Vite includes them in the build)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SECRET - only used locally when running scripts/generateQuizzes.mjs. Never commit this,
# never put it in Netlify's site env vars, never prefix it with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
